{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Voxbridge",
  "version": "0.1.1",
  "identifier": "com.github.lzkdev.voxbridge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "Voxbridge",
        "url": "panel.html",
        "width": 380,
        "height": 560,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "subtitle",
        "title": "Voxbridge Subtitles",
        "url": "subtitle.html",
        "width": 500,
        "height": 120,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
